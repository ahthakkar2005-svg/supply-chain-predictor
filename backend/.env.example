# Supply Chain Disruption Predictor - Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME="Supply Chain Disruption Predictor"
APP_VERSION="1.0.0"
DEBUG=true

# API Keys (optional - system uses mock data if not provided)
NEWS_API_KEY=
TWITTER_API_KEY=
OPENAI_API_KEY=
OPENWEATHER_API_KEY=

# Real-time Settings
REALTIME_INTERVAL=5
NEWS_FETCH_INTERVAL=60

# Database (optional - using in-memory for MVP)
DATABASE_URL=sqlite:///./supply_chain.db
MONGODB_URL=mongodb://localhost:27017

# ML Model Settings
MODEL_UPDATE_INTERVAL=3600
PREDICTION_HORIZON_DAYS=30
RISK_THRESHOLD_HIGH=0.7
RISK_THRESHOLD_MEDIUM=0.4

# Alert Settings
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_RECIPIENTS=
