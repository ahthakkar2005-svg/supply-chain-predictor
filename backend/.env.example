# Supply Chain Disruption Predictor - Environment Configuration
# Copy to .env and fill in real values

# Application
APP_NAME="Supply Chain Disruption Predictor"
APP_VERSION="2.0.0"
DEBUG=false
ENV=development

# API Keys (NEVER commit real values)
NEWS_API_KEY=your_newsapi_key_here
TWITTER_API_KEY=
OPENAI_API_KEY=
OPENWEATHER_API_KEY=your_openweathermap_key_here

# JWT Authentication
JWT_SECRET_KEY=change-this-to-a-random-64-char-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Real-time Settings
REALTIME_INTERVAL=5
NEWS_FETCH_INTERVAL=60

# Database
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=supply_chain_predictor

# Redis
REDIS_URL=redis://localhost:6379/0

# ML Model Settings
MODEL_UPDATE_INTERVAL=3600
PREDICTION_HORIZON_DAYS=30
RISK_THRESHOLD_HIGH=0.7
RISK_THRESHOLD_MEDIUM=0.4

# Alert Settings
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_RECIPIENTS=
SENDGRID_API_KEY=your_sendgrid_key_here
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Observability
SENTRY_DSN=
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# AWS Secrets Manager (optional — overrides local .env when set)
AWS_SECRETS_NAME=
AWS_REGION=us-east-1
